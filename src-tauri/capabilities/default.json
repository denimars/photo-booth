{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Photo Booth default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        "$PICTURE/**",
        "$APPDATA/**"
      ]
    },
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission"
  ]
}
